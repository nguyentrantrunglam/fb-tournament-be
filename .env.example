# ---- badminton-api environment ----
NODE_ENV=development
PORT=3001

# MongoDB — MUST be a replica set (multi-doc transactions used in bracket/cascade/end-match)
# Dev (docker-compose 1-node RS): directConnection avoids SRV/host resolution issues
MONGO_URI=mongodb://localhost:27017/badminton?replicaSet=rs0&directConnection=true

# Session (express-session + connect-mongo). connect.sid shared REST + Socket.IO
SESSION_SECRET=change-me-in-prod
# Web origin allowed for CORS credentials (Vercel domain in prod)
WEB_ORIGIN=http://localhost:3000
# Cookie: lax for same-site dev; none+secure required cross-origin prod (web Vercel <-> api domain)
COOKIE_SAMESITE=lax
COOKIE_SECURE=false

# S3 storage. Dev = MinIO (docker-compose); prod = DigitalOcean Spaces.
# --- MinIO (dev) ---
SPACES_ENDPOINT=http://localhost:9000
SPACES_REGION=us-east-1
SPACES_KEY=minioadmin
SPACES_SECRET=minioadmin
SPACES_BUCKET=badminton-dev
SPACES_FORCE_PATH_STYLE=true
SPACES_PUBLIC_BASE_URL=http://localhost:9000/badminton-dev
# --- DigitalOcean Spaces (prod) example ---
# SPACES_ENDPOINT=https://sgp1.digitaloceanspaces.com
# SPACES_REGION=sgp1
# SPACES_KEY=...
# SPACES_SECRET=...
# SPACES_BUCKET=badminton
# SPACES_FORCE_PATH_STYLE=false
# SPACES_PUBLIC_BASE_URL=https://badminton.sgp1.digitaloceanspaces.com

# SMTP for forgot-password (Phase 2). Leave blank in dev to log reset links instead of sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@badminton.local
